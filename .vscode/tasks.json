{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build hello_world",
      "type": "shell",
      "command": "gcc",
      "args": ["hello_world.c", "-o", "hello", "-g", "-Wall"],
      "options": {
        "cwd": "${workspaceFolder}/tutorials"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    }
  ]
}
